<input>
    <memory type="coarse" comment="Summary of previous events">
        {$COARSE_MEMORY}
    </memory>
    <memory type="precise" comment="Summary of recent events">
        {$PRECISE_MEMORY}
    </memory>

    <simulator comment="Output before player's action">
        {$SIMULATOR_OUTPUT_BEFORE_PLAYER_ACTION}
    </simulator>
    <status comment="Previous status bar (may be empty on first input)">
        {$PREVIOUS_STATUS_BAR}
    </status>

    <player comment="Player's action">
        {$PLAYER_ACTION}
    </player>

    <simulator comment="Output after player's action">
        {$SIMULATOR_OUTPUT_AFTER_PLAYER_ACTION}
    </simulator>
</input>
